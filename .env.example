# Copy this to `.env` and uncomment the lines that apply to your host.
# `.env` is gitignored — each contributor's machine carries its own truth.
#
# By default, `cargo test` runs the full real-runtime e2e suite against
# live podman and (if a cluster is reachable) live kubernetes. Disable
# whichever your host can't run.

# Set to false on hosts without rootless podman installed.
#BERTH_E2E_PODMAN_ENABLED=false

# Set to false on hosts without a reachable kubeconfig + cluster.
# kubectl-on-PATH alone is not enough — the test creates a pod.
#BERTH_E2E_K8S_ENABLED=false
